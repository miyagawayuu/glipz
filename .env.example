# Copy this file to .env and fill in only the values you need.
# Never commit your real .env file or any production secrets to GitHub.

# =========================================================
# Required: Backend
# =========================================================

# Required: 64+ character random secret. Generate one, for example:
# openssl rand -base64 48
JWT_SECRET=

# Optional: runtime app version override for federation metadata.
# When omitted, the version synced from web/package.json is exposed.
GLIPZ_VERSION=dev
#
# Optional but strongly recommended for federated production instances:
# dedicated Ed25519 federation signing key material, separate from JWT_SECRET.
# Generate a seed with: openssl rand -base64 32
# GLIPZ_FEDERATION_KEY_SEED=
# Advanced: base64-encoded 64-byte Ed25519 private key.
# GLIPZ_FEDERATION_PRIVATE_KEY=

# Optional: expose lightweight expvar metrics at /debug/vars.
# Keep this behind a trusted network or reverse-proxy allowlist in production.
# GLIPZ_METRICS_ENABLED=false
#
# Optional: enable per-request access logs.
# Disabled by default for throughput.
# GLIPZ_ACCESS_LOG_ENABLED=false
#
# Optional: log HTTP requests slower than this many milliseconds.
# Disabled by default; 750 is useful while profiling.
# GLIPZ_SLOW_REQUEST_LOG_MS=0
#
# Optional: trust X-Real-IP / X-Forwarded-For for auth rate limits.
# Enable only behind a reverse proxy that overwrites these headers and prevents
# direct access to the backend port.
# GLIPZ_TRUST_PROXY_HEADERS=false
# Optional: only trust proxy headers from these direct peer CIDRs.
# Example for loopback proxy: GLIPZ_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
# GLIPZ_TRUSTED_PROXY_CIDRS=
#
# Optional: reject login/MFA attempts when Redis-backed auth rate limits fail.
# Default fail-open preserves availability; production deployments should prefer
# fail-closed after Redis health checks and alerting are in place.
# GLIPZ_AUTH_RATE_LIMIT_FAIL_CLOSED=false
# Optional: reject remote-media proxy requests when Redis-backed rate limits fail.
# Production deployments should prefer fail-closed for stricter public proxy controls.
# GLIPZ_REMOTE_MEDIA_PROXY_RATE_LIMIT_FAIL_CLOSED=false
#
# Optional: public link-preview requests allowed per IP/user per 15 minutes.
# GLIPZ_LINK_PREVIEW_RATE_LIMIT_MAX=60
# Optional: reject link-preview requests when Redis-backed rate limits fail.
# Production deployments should prefer fail-closed for stricter public proxy controls.
# GLIPZ_LINK_PREVIEW_RATE_LIMIT_FAIL_CLOSED=false
#
# Optional: reject federation inbox POSTs when Redis-backed rate limits fail.
# Production deployments should prefer fail-closed for stricter federation abuse controls.
# GLIPZ_FEDERATION_INBOX_RATE_LIMIT_FAIL_CLOSED=false
#
# Production hardening note:
# The fail-closed flags above trade availability for abuse resistance when Redis
# is unavailable. Consider enabling them for internet-facing production instances
# after Redis monitoring and alerting are in place.
#
# Optional: authenticated feed page size. Lower values reduce payload size under load.
# GLIPZ_FEED_PAGE_SIZE=30

# Optional: comma-separated user IDs with admin privileges
# These users can open the /admin control panel.
GLIPZ_ADMIN_USER_IDS=

# Optional: short federation policy summary shown by your instance
# FEDERATION_POLICY_SUMMARY=This instance welcomes federation.

# =========================================================
# Database / Redis
# =========================================================
# When using docker compose, these are usually provided by compose.
# Set them only when running the backend without docker compose.

# Local development example. Use sslmode=require or stronger for production DBs.
# DATABASE_URL=postgres://glipz:glipz_dev@127.0.0.1:5432/glipz?sslmode=disable
# REDIS_URL=redis://127.0.0.1:6379/0

# =========================================================
# Media storage
# =========================================================
# Choose one:
# - local: store media under GLIPZ_LOCAL_STORAGE_PATH on this server
# - s3: store media in S3-compatible storage
# If GLIPZ_STORAGE_MODE is left unset, the backend defaults to s3 and requires
# the S3_* values below. For the local Docker Compose stack, uncomment local.
# GLIPZ_STORAGE_MODE=s3
#
# Local folder storage example:
# S3_* values are not required when GLIPZ_STORAGE_MODE=local.
# Docker Compose mounts ./data/media into the backend container.
# GLIPZ_STORAGE_MODE=local
# GLIPZ_LOCAL_STORAGE_PATH=./data/media
#
# S3-compatible storage example (required when GLIPZ_STORAGE_MODE=s3):

# S3_ENDPOINT=http://127.0.0.1:9000
# S3_PUBLIC_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=glipz-media
# S3_USE_PATH_STYLE=true
#
# Wasabi example:
# S3_ENDPOINT=https://s3.ap-northeast-1.wasabisys.com
# S3_PUBLIC_ENDPOINT=https://s3.ap-northeast-1.wasabisys.com
# S3_REGION=ap-northeast-1
# S3_ACCESS_KEY=your-wasabi-access-key
# S3_SECRET_KEY=your-wasabi-secret-key
# S3_BUCKET=your-bucket-name
# S3_USE_PATH_STYLE=false
#
# Cloudflare R2 example:
# - S3_ENDPOINT and S3_PUBLIC_ENDPOINT are the R2 S3 API endpoint used for signed uploads.
# - GLIPZ_PROTOCOL_MEDIA_PUBLIC_BASE below should be your R2 custom public domain.
# - S3_USE_PATH_STYLE is auto-enabled for *.r2.cloudflarestorage.com, but can be set explicitly.
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_PUBLIC_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY=your-r2-access-key-id
# S3_SECRET_KEY=your-r2-secret-access-key
# S3_BUCKET=your-r2-bucket-name
# S3_USE_PATH_STYLE=true

# =========================================================
# Frontend / Static serving
# =========================================================

# Backend-side path to built frontend assets when serving static files directly
# STATIC_WEB_ROOT=../web/dist
#
# Optional: directory containing operator-editable Markdown policy files.
# Supported files are terms.md, privacy.md, nsfw-guidelines.md, and law-enforcement.md.
# Locale-specific files such as terms.ja.md or terms.en.md take precedence.
# Docker Compose mounts ./data/legal-docs to /app/data/legal-docs by default.
# LEGAL_DOCS_DIR=./data/legal-docs

# Frontend origin(s) used by the backend.
# If using both apex and www in production, specify comma-separated values.
# The first value is treated as the primary origin for email links and similar uses.
# FRONTEND_ORIGIN=http://localhost:5173
# FRONTEND_ORIGIN=https://glipz.io,https://www.glipz.io

# Frontend build-time variables
# These are mainly used by Vite / web builds.
# If serving the API on the same origin under /api, VITE_API_URL can usually be omitted.

# VITE_API_URL=http://localhost:8080
# VITE_PROXY_TARGET=http://127.0.0.1:8080
# Vite dev server host. Keep localhost by default; set 0.0.0.0 only for trusted LAN testing.
# VITE_DEV_HOST=127.0.0.1

# Production web build note:
# web/.env.production is used by npm run build.
# If using Capacitor/native builds, set VITE_NATIVE_API_URL to your fixed HTTPS API origin.
# Native builds no longer accept a user-editable API origin at login time.
# VITE_NATIVE_API_URL=https://api.example.com
# If DM attachments are served from a CDN, set comma-separated HTTPS base URLs
# including a non-root object path prefix, not just the origin. Root prefixes are rejected.
# VITE_ALLOWED_DM_ATTACHMENT_BASE_URLS=https://media.example.com/dm/
# Also make sure FRONTEND_ORIGIN on the backend includes the WebView origin.
# If the API is cross-origin, proper CORS configuration is required.

# =========================================================
# Glipz Protocol (optional)
# =========================================================

# Public origin used for federation/discovery endpoints
# GLIPZ_PROTOCOL_PUBLIC_ORIGIN=http://localhost:8080
# Example production value: https://api.example.com

# Public host shown in discovery / account identity
# GLIPZ_PROTOCOL_HOST=example.com

# Public media base URL (for CDN or backend media proxy URLs)
# Example: https://your-app.example.com/api/v1/media/object
# Wasabi + backend media proxy example: https://your-app.example.com/api/v1/media/object
# Cloudflare R2 custom domain example: https://media.example.com
# GLIPZ_PROTOCOL_MEDIA_PUBLIC_BASE=https://your-app.example.com/api/v1/media/object
#
# Media serving mode:
# - proxy: backend streams local/S3 objects through /api/v1/media/object (default)
# - direct: /api/v1/media/object redirects to GLIPZ_PROTOCOL_MEDIA_PUBLIC_BASE or S3 public URLs,
#   useful with CDN/R2 direct delivery or when a reverse proxy serves GLIPZ_LOCAL_STORAGE_PATH directly
#   local storage without GLIPZ_PROTOCOL_MEDIA_PUBLIC_BASE falls back to proxy
# GLIPZ_MEDIA_PROXY_MODE=proxy
#
# Maximum bytes streamed by remote-media and federated-DM attachment proxies.
# Defaults are 50 MiB; accepted values are 1 MiB to 512 MiB.
# GLIPZ_REMOTE_MEDIA_PROXY_MAX_BYTES=52428800
# GLIPZ_FEDERATION_DM_ATTACHMENT_MAX_BYTES=52428800
# Public remote-media proxy requests allowed per IP per 15 minutes.
# GLIPZ_REMOTE_MEDIA_PROXY_RATE_LIMIT_MAX=120
# Optional: comma-separated media/CDN base URLs for frontend lightbox links.
# Include a non-root path prefix; root origins are rejected.
# VITE_ALLOWED_MEDIA_BASE_URLS=https://cdn.example.com/media/
#
# Outbound federation delivery worker tuning
# GLIPZ_FEDERATION_DELIVERY_BATCH_SIZE=25
# GLIPZ_FEDERATION_DELIVERY_CONCURRENCY=1
# GLIPZ_FEDERATION_DELIVERY_TICK_SECONDS=8

# =========================================================
# Patreon (fan club, optional)
# =========================================================
# Create an API client at https://www.patreon.com/portal/registration/register-clients
# Redirect URI should match: {GLIPZ_PROTOCOL_PUBLIC_ORIGIN}/api/v1/fanclub/patreon/callback
# (or set PATREON_REDIRECT_URI explicitly).
# Disabled by default. Set PATREON_ENABLED=true to show Patreon UI and enable routes.
# PATREON_ENABLED=false
# PATREON_CLIENT_ID=
# PATREON_CLIENT_SECRET=
# PATREON_REDIRECT_URI=https://api.example.com/api/v1/fanclub/patreon/callback

# =========================================================
# Legacy names (backward compatibility only)
# =========================================================
# These older names are still accepted for compatibility,
# but should not be used for new configurations.

# GLIPZ_FEDERATION_PUBLIC_ORIGIN=http://localhost:8080
# GLIPZ_FEDERATION_HOST=example.com
# MEDIA_PUBLIC_BASE=https://your-cdn.example.com/glipz-media
# ACTIVITYPUB_PUBLIC_ORIGIN=http://localhost:8080
# ACTIVITYPUB_WEBFINGER_HOST=example.com
# ACTIVITYPUB_MEDIA_PUBLIC_BASE=https://your-cdn.example.com/glipz-media

# =========================================================
# Registration / email verification
# =========================================================

# REGISTRATION_VERIFY_TTL=30m

# Production mail delivery example (Mailgun)
# MAILGUN_DOMAIN=example.com
# MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MAILGUN_API_BASE=https://api.eu.mailgun.net
#
# Alternative production mail delivery example (SMTP)
# Used when Mailgun is not configured. SMTP_TLS accepts auto, starttls, tls, or none.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_TLS=auto

# Common sender settings
# MAIL_FROM_EMAIL=no-reply@example.com
# MAIL_FROM_NAME=Glipz
#
# SMTP-specific sender aliases are also accepted for local compose/Mailpit compatibility.
# SMTP_FROM_EMAIL=no-reply@example.com
# SMTP_FROM_NAME=Glipz

# Local development tip:
# If you use Mailpit via docker compose, SMTP settings may be injected by compose
# and do not need to be set here.

# =========================================================
# Web Push (optional)
# =========================================================

# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_VAPID_SUBJECT=mailto:no-reply@example.com