# Copy this file to .env and fill in only the values you need.
# Never commit your real .env file or any production secrets to GitHub.

# =========================================================
# Required: Backend
# =========================================================

# Replace with a long random secret in production.
JWT_SECRET=replace-with-a-long-random-secret

# Optional: app / build metadata
GLIPZ_VERSION=dev

# Optional: comma-separated user IDs with admin privileges
GLIPZ_ADMIN_USER_IDS=

# Optional: short federation policy summary shown by your instance
# FEDERATION_POLICY_SUMMARY=This instance welcomes federation.

# =========================================================
# Database / Redis
# =========================================================
# When using docker compose, these are usually provided by compose.
# Set them only when running the backend without docker compose.

# DATABASE_URL=postgres://glipz:glipz_dev@127.0.0.1:5432/glipz?sslmode=disable
# REDIS_URL=redis://127.0.0.1:6379/0

# =========================================================
# S3 / Wasabi (or other S3-compatible storage)
# =========================================================
# These are required for both docker compose and direct backend runs.

# S3_ENDPOINT=http://127.0.0.1:9000
# S3_PUBLIC_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=glipz-media
# S3_USE_PATH_STYLE=true
#
# Wasabi example:
# S3_ENDPOINT=https://s3.ap-northeast-1.wasabisys.com
# S3_PUBLIC_ENDPOINT=https://s3.ap-northeast-1.wasabisys.com
# S3_REGION=ap-northeast-1
# S3_ACCESS_KEY=your-wasabi-access-key
# S3_SECRET_KEY=your-wasabi-secret-key
# S3_BUCKET=your-bucket-name
# S3_USE_PATH_STYLE=false

# =========================================================
# Frontend / Static serving
# =========================================================

# Backend-side path to built frontend assets when serving static files directly
# STATIC_WEB_ROOT=../web/dist

# Frontend origin(s) used by the backend.
# If using both apex and www in production, specify comma-separated values.
# The first value is treated as the primary origin for email links and similar uses.
# FRONTEND_ORIGIN=http://localhost:5173
# FRONTEND_ORIGIN=https://glipz.io,https://www.glipz.io

# Frontend build-time variables
# These are mainly used by Vite / web builds.
# If serving the API on the same origin under /api, VITE_API_URL can usually be omitted.

# VITE_API_URL=http://localhost:8080
# VITE_PROXY_TARGET=http://127.0.0.1:8080

# Production web build note:
# web/.env.production is used by npm run build.
# If using Capacitor, set VITE_API_URL there to your HTTPS API origin.
# Also make sure FRONTEND_ORIGIN on the backend includes the WebView origin.
# If the API is cross-origin, proper CORS configuration is required.

# =========================================================
# Glipz Protocol (optional)
# =========================================================

# Public origin used for federation/discovery endpoints
# GLIPZ_PROTOCOL_PUBLIC_ORIGIN=http://localhost:8080
# Example production value: https://api.example.com

# Public host shown in discovery / account identity
# GLIPZ_PROTOCOL_HOST=example.com

# Public media base URL (for CDN or backend media proxy URLs)
# Example: https://your-app.example.com/api/v1/media/object
# Wasabi + backend media proxy example: https://your-app.example.com/api/v1/media/object
# GLIPZ_PROTOCOL_MEDIA_PUBLIC_BASE=https://your-app.example.com/api/v1/media/object

# =========================================================
# Patreon (fan club, optional)
# =========================================================
# Create an API client at https://www.patreon.com/portal/registration/register-clients
# Redirect URI should match: {GLIPZ_PROTOCOL_PUBLIC_ORIGIN}/api/v1/fanclub/patreon/callback
# (or set PATREON_REDIRECT_URI explicitly).
# PATREON_CLIENT_ID=
# PATREON_CLIENT_SECRET=
# PATREON_REDIRECT_URI=https://api.example.com/api/v1/fanclub/patreon/callback
#
# Gumroad fan club locks use the public license verification endpoint.
# No server-side env var is required; creators enter their Membership product_id
# when composing a Gumroad-locked post, and viewers enter their license key to unlock.

# =========================================================
# Legacy names (backward compatibility only)
# =========================================================
# These older names are still accepted for compatibility,
# but should not be used for new configurations.

# GLIPZ_FEDERATION_PUBLIC_ORIGIN=http://localhost:8080
# GLIPZ_FEDERATION_HOST=example.com
# MEDIA_PUBLIC_BASE=https://your-cdn.example.com/glipz-media
# ACTIVITYPUB_PUBLIC_ORIGIN=http://localhost:8080
# ACTIVITYPUB_WEBFINGER_HOST=example.com
# ACTIVITYPUB_MEDIA_PUBLIC_BASE=https://your-cdn.example.com/glipz-media

# =========================================================
# Registration / email verification
# =========================================================

# REGISTRATION_VERIFY_TTL=30m

# Production mail delivery example (Mailgun)
# MAILGUN_DOMAIN=example.com
# MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MAILGUN_API_BASE=https://api.eu.mailgun.net

# Common sender settings
# MAIL_FROM_EMAIL=no-reply@example.com
# MAIL_FROM_NAME=Glipz

# Local development tip:
# If you use Mailpit via docker compose, SMTP settings may be injected by compose
# and do not need to be set here.

# =========================================================
# TURN (coturn) DM calls (recommended)
# =========================================================
#
# Provide UDP:3478, TCP:3478 and TURNS:443 on the same host.
# The backend issues time-limited TURN credentials using TURN_SHARED_SECRET.
#
# TURN_HOST=turn.glipz.io
# TURN_PORT=3478
# TURNS_PORT=443
# TURN_SHARED_SECRET=replace-with-a-long-random-secret
# TURN_TTL_SECONDS=600

# =========================================================
# Web Push (optional)
# =========================================================

# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_VAPID_SUBJECT=mailto:no-reply@example.com